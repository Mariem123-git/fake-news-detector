 # SHAP Waterfall — Explication d'un faux négatif (fake non détecté)
import shap
import matplotlib.pyplot as plt

# On prend le faux négatif le plus trompeur (proba_fake la plus basse)
fn_index = faux_negatifs.index[0]
fn_position = list(X_test_text_reset.index).index(fn_index) if fn_index < 500 else 0

print(" Article analysé :")
print(f"   Vrai label : FAKE | Prédit : RÉEL (le modèle s'est trompé)")
print(f"   Probabilité fake estimée : {faux_negatifs['proba_fake'].iloc[0]:.3f}")
print(f"\n   Texte : {faux_negatifs['texte'].iloc[0][:200]}...\n")

shap.waterfall_plot(
    shap.Explanation(
        values=shap_values[fn_position],
        base_values=explainer.expected_value,
        data=X_test_sample[fn_position].toarray()[0],
        feature_names=list(feature_names)
    ),
    max_display=15,
    show=False
)
plt.title("Pourquoi le modèle n'a pas détecté ce fake ? (SHAP waterfall)", fontweight="bold")
plt.tight_layout()
plt.show()


