# Si fp_position est hors de shap_values, on recalcule sur la ligne exacte
if fp_index >= len(shap_values):
    X_fp_single    = X_test[fp_index]
    shap_values_fp = explainer.shap_values(X_fp_single)
    fp_values      = shap_values_fp.toarray()[0] if hasattr(shap_values_fp, 'toarray') else np.array(shap_values_fp).flatten()
    fp_data        = X_test[fp_index].toarray()[0]
else:
    fp_values = shap_values[fp_position]
    fp_data   = X_test_sample[fp_position].toarray()[0]

print(" Article analysé :")
print(f"   Vrai label : RÉEL | Prédit : FAKE (le modèle s'est trompé)")
