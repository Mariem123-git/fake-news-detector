import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.feature_extraction.text import CountVectorizer

#  1. Fonction n-grams
def get_top_text_ngrams(corpus, n, g):
    vec = CountVectorizer(ngram_range=(g, g), stop_words='english')
    bag_of_words = vec.fit_transform(corpus)

    sum_words = bag_of_words.sum(axis=0)
    words_freq = [(word, sum_words[0, idx]) for word, idx in vec.vocabulary_.items()]

    words_freq = sorted(words_freq, key=lambda x: x[1], reverse=True)
    return words_freq[:n]
#  2. Fake News
fake_text = df[df["label"] == 1]["text"].dropna()

most_common_fake = get_top_text_ngrams(fake_text, 10, 1)
most_common_fake = dict(most_common_fake)

plt.figure(figsize=(8,3))
sns.barplot(x=list(most_common_fake.values()), y=list(most_common_fake.keys()))
plt.title("Top Bigrams - Fake News")
plt.xlabel("Fréquence")
plt.ylabel("Bigrams")
plt.show()

#  3. Real News
real_text = df[df["label"] == 0]["text"].dropna()

most_common_real = get_top_text_ngrams(real_text, 10, 1)
most_common_real = dict(most_common_real)

plt.figure(figsize=(8,3))
sns.barplot(x=list(most_common_real.values()), y=list(most_common_real.keys()))
plt.title("Top Bigrams - Real News")
plt.xlabel("Fréquence")
plt.ylabel("Bigrams")
plt.show()

