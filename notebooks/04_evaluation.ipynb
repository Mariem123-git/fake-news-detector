from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay
import matplotlib.pyplot as plt

models_preds = {
    "Naive Bayes": y_pred_nb,
    "Logistic Regression": y_pred_lr,
    "LR (Tuned)": y_pred_lr_best,
    "SVM": y_pred_svm,
    "SVM (Tuned)": y_pred_svm_best,
    "Random Forest": y_pred_rf,
    "Decision Tree": y_pred_dt
}

fig, axes = plt.subplots(2, 4, figsize=(24, 12))
axes = axes.flatten()

for i, (name, y_pred) in enumerate(models_preds.items()):
    cm = confusion_matrix(y_test, y_pred)
    disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=["Real (0)", "Fake (1)"])
    disp.plot(ax=axes[i], colorbar=False, cmap="Blues")
    axes[i].set_title(name, fontsize=13, fontweight="bold")

axes[-1].axis("off")
plt.suptitle("Matrices de Confusion — Tous les modèles", fontsize=16, fontweight="bold")
plt.tight_layout()
plt.show()


from sklearn.metrics import roc_curve, auc
import matplotlib.pyplot as plt

plt.figure(figsize=(12, 8))

models_proba = {
    "Naive Bayes": nb_model,
    "Logistic Regression": lr_model,
    "LR (Tuned)": best_lr,
    "Random Forest": rf_model,
    "Decision Tree": dt_model,
}

colors = ["#e74c3c", "#3498db", "#2ecc71", "#f39c12", "#9b59b6"]

for (name, model), color in zip(models_proba.items(), colors):
    y_proba = model.predict_proba(X_test)[:, 1]
    fpr, tpr, _ = roc_curve(y_test, y_proba)
    roc_auc = auc(fpr, tpr)
    plt.plot(fpr, tpr, color=color, lw=2, label=f"{name} (AUC = {roc_auc:.4f})")

for model_name, model_obj in [("SVM", svm_model), ("SVM (Tuned)", best_svm)]:
    scores = model_obj.decision_function(X_test)
    scores_scaled = (scores - scores.min()) / (scores.max() - scores.min())
    fpr, tpr, _ = roc_curve(y_test, scores_scaled)
    roc_auc = auc(fpr, tpr)
    plt.plot(fpr, tpr, lw=2, linestyle="--", label=f"{model_name} (AUC = {roc_auc:.4f})")

plt.plot([0, 1], [0, 1], 'k--', lw=1.5, label="Aléatoire (AUC = 0.5)")
plt.xlabel("Taux de Faux Positifs (FPR)", fontsize=13)
plt.ylabel("Taux de Vrais Positifs (TPR)", fontsize=13)
plt.title("Courbes ROC — Comparaison de tous les modèles", fontsize=15, fontweight="bold")
plt.legend(loc="lower right", fontsize=10)
plt.grid(alpha=0.3)
plt.tight_layout()
plt.show()


from sklearn.metrics import precision_recall_curve, average_precision_score
import matplotlib.pyplot as plt

plt.figure(figsize=(12, 7))

for (name, model), color in zip(models_proba.items(), colors):
    y_proba = model.predict_proba(X_test)[:, 1]
    precision, recall, _ = precision_recall_curve(y_test, y_proba)
    ap = average_precision_score(y_test, y_proba)
    plt.plot(recall, precision, color=color, lw=2, label=f"{name} (AP = {ap:.4f})")

plt.xlabel("Recall", fontsize=13)
plt.ylabel("Precision", fontsize=13)
plt.title("Courbes Precision-Recall — Comparaison des modèles", fontsize=15, fontweight="bold")
plt.legend(loc="lower left", fontsize=10)
plt.grid(alpha=0.3)
plt.tight_layout()
plt.show()


import numpy as np
import matplotlib.pyplot as plt
from sklearn.metrics import f1_score, precision_score, recall_score

y_proba_best = best_lr.predict_proba(X_test)[:, 1]
thresholds = np.arange(0.1, 0.9, 0.01)

f1_scores, precisions, recalls = [], [], []

for thresh in thresholds:
    y_pred_thresh = (y_proba_best >= thresh).astype(int)
    f1_scores.append(f1_score(y_test, y_pred_thresh))
    precisions.append(precision_score(y_test, y_pred_thresh, zero_division=0))
    recalls.append(recall_score(y_test, y_pred_thresh, zero_division=0))

best_thresh = thresholds[np.argmax(f1_scores)]

plt.figure(figsize=(12, 6))
plt.plot(thresholds, f1_scores, label="F1-score", color="#2ecc71", lw=2.5)
plt.plot(thresholds, precisions, label="Precision", color="#3498db", lw=2, linestyle="--")
plt.plot(thresholds, recalls, label="Recall", color="#e74c3c", lw=2, linestyle="--")
plt.axvline(x=best_thresh, color="black", linestyle=":", lw=2,
            label=f"Seuil optimal = {best_thresh:.2f}")
plt.axvline(x=0.5, color="gray", linestyle=":", lw=1.5, label="Seuil par défaut = 0.5")
plt.xlabel("Seuil de décision", fontsize=13)
plt.ylabel("Score", fontsize=13)
plt.title("Impact du seuil de décision sur les métriques (LR Tuned)", fontsize=14, fontweight="bold")
plt.legend(fontsize=11)
plt.grid(alpha=0.3)
plt.tight_layout()
plt.show()

print(f"Seuil par défaut (0.5) → F1 = {f1_score(y_test, (y_proba_best >= 0.5).astype(int)):.4f}")
print(f"Seuil optimal ({best_thresh:.2f})  → F1 = {max(f1_scores):.4f}")


from sklearn.metrics import confusion_matrix
import pandas as pd
import matplotlib.pyplot as plt

risk_results = []

for name, y_pred in models_preds.items():
    cm = confusion_matrix(y_test, y_pred)
    TN, FP, FN, TP = cm.ravel()
    risk_results.append({
        "Modèle": name,
        "TP": TP, "TN": TN, "FP": FP, "FN": FN,
        "Taux FP (%)": round(FP / (FP + TN) * 100, 2),
        "Taux FN (%)": round(FN / (FN + TP) * 100, 2),
    })

risk_df = pd.DataFrame(risk_results).sort_values("Taux FN (%)")
print(risk_df.to_string(index=False))

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))

ax1.barh(risk_df["Modèle"], risk_df["Taux FP (%)"], color="#3498db")
ax1.set_title("Risque Type I — Censure injuste\n(Real classé comme Fake)", fontsize=12)
ax1.set_xlabel("Taux Faux Positifs (%)")
ax1.axvline(x=risk_df["Taux FP (%)"].mean(), color='black', linestyle='--', label='Moyenne')
ax1.legend()

ax2.barh(risk_df["Modèle"], risk_df["Taux FN (%)"], color="#e74c3c")
ax2.set_title("Risque Type II — Danger principal\n(Fake classé comme Real)", fontsize=12)
ax2.set_xlabel("Taux Faux Négatifs (%)")
ax2.axvline(x=risk_df["Taux FN (%)"].mean(), color='black', linestyle='--', label='Moyenne')
ax2.legend()

plt.suptitle("Analyse des Risques par Modèle", fontsize=15, fontweight="bold")
plt.tight_layout()
plt.show()

print(f"\nMeilleur modèle en gestion du risque : {risk_df.iloc[0]['Modèle']}")
print(f"Taux de Faux Négatifs : {risk_df.iloc[0]['Taux FN (%)']}%")


import pandas as pd
import matplotlib.pyplot as plt

X_test_text_reset = X_test_text.reset_index(drop=True)
y_test_reset = y_test.reset_index(drop=True)
y_proba_all = best_lr.predict_proba(X_test)[:, 1]
y_pred_all = best_lr.predict(X_test)

error_df = pd.DataFrame({
    "texte": X_test_text_reset,
    "label_réel": y_test_reset,
    "label_prédit": y_pred_all,
    "proba_fake": y_proba_all
})

faux_negatifs = error_df[(error_df["label_réel"] == 1) & (error_df["label_prédit"] == 0)].sort_values("proba_fake")
faux_positifs = error_df[(error_df["label_réel"] == 0) & (error_df["label_prédit"] == 1)].sort_values("proba_fake", ascending=False)

print(f"Nombre de Faux Négatifs (Fake non détectés) : {len(faux_negatifs)}")
print(f"Nombre de Faux Positifs (Real mal classés)  : {len(faux_positifs)}")

pd.set_option('display.max_colwidth', 200)
print("\n--- Faux Négatifs les plus trompeurs ---")
print(faux_negatifs[["texte", "proba_fake"]].head(3).to_string())

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))
ax1.hist(faux_negatifs["proba_fake"], bins=30, color="#e74c3c", alpha=0.8)
ax1.set_title("Faux Négatifs\n(Fake non détectés)", fontweight="bold")
ax1.set_xlabel("Probabilité estimée d'être Fake")
ax1.set_ylabel("Nombre d'articles")

ax2.hist(faux_positifs["proba_fake"], bins=30, color="#3498db", alpha=0.8)
ax2.set_title("Faux Positifs\n(Real classés comme Fake)", fontweight="bold")
ax2.set_xlabel("Probabilité estimée d'être Fake")

plt.suptitle("Distribution des erreurs du modèle", fontsize=14, fontweight="bold")
plt.tight_layout()
plt.show()


